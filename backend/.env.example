# ============================================================
# Smart Home Energy Management System - Environment Variables
# Copy this file to .env and fill in your actual values
# ============================================================

# ----- Server Configuration -----
SERVER_PORT=8081

# ----- MySQL Database Configuration -----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=smarthome_db
DB_USERNAME=root
DB_PASSWORD=your_database_password

# ----- JPA / Hibernate -----
JPA_HIBERNATE_DDL_AUTO=update
JPA_SHOW_SQL=false

# ----- JWT Configuration -----
# Generate a strong secret key (min 32 chars, base64 recommended)
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRATION_MS=86400000

# ----- Email / SMTP Configuration -----
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_CONNECTION_TIMEOUT=5000
MAIL_SMTP_TIMEOUT=3000
MAIL_SMTP_WRITE_TIMEOUT=5000

# Reset code expiry (10 minutes in ms)
RESET_CODE_EXPIRY_MS=600000

# ----- Google OAuth2 Configuration -----
OAUTH2_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
OAUTH2_GOOGLE_CLIENT_SECRET=your_google_client_secret
OAUTH2_GOOGLE_SCOPE=email,profile
OAUTH2_GOOGLE_REDIRECT_URI=http://localhost:8081/login/oauth2/code/google
OAUTH2_REDIRECT_URI=http://localhost:3000

# ----- Admin emails (comma-separated) -----
APP_ADMIN_EMAILS=admin@gmail.com

# ----- CORS Configuration -----
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ----- Logging -----
LOG_LEVEL_SPRING_SECURITY=WARN
LOG_LEVEL_APP=INFO
